{
  "name": "lightsaber-rpa",
  "private": true,
  "version": "0.1.0",
  "description": "Windows-first desktop RPA monorepo.",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev:runner": "pnpm --filter @lightsaber-rpa/runner dev",
    "dev:studio": "pnpm --filter @lightsaber-rpa/studio dev",
    "format": "pnpm -r --if-present format",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck"
  }
}
