{
  "name": "lightsaber-rpa",
  "private": true,
  "version": "0.1.0",
  "description": "Windows-first desktop RPA monorepo.",
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "scripts": {
    "build": "corepack pnpm -r --if-present build",
    "build:studio": "corepack pnpm --filter @lightsaber-rpa/studio build",
    "dev:runner": "corepack pnpm --filter @lightsaber-rpa/runner dev",
    "dev:studio": "corepack pnpm --filter @lightsaber-rpa/studio dev",
    "format": "corepack pnpm -r --if-present format",
    "lint": "corepack pnpm -r --if-present lint",
    "typecheck": "corepack pnpm -r --if-present typecheck",
    "typecheck:studio": "corepack pnpm --filter @lightsaber-rpa/studio typecheck"
  }
}
